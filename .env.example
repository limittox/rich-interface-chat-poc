# Provider keys — set ONE of the two. The /api/chat route prefers OpenRouter
# when OPENROUTER_API_KEY is set, otherwise falls back to Anthropic direct.

# Option A (primary): OpenRouter
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-opus-4-8

# Option B: Anthropic direct
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
